{
	"name": "ai-cortex",
	"version": "0.13.0",
	"description": "Local project rehydration, file discovery, and session-history MCP server for AI agents (Claude Code, Codex)",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ai-creed/ai-cortex.git"
	},
	"homepage": "https://ai-creed.dev/projects/ai-cortex/",
	"keywords": [
		"ai-agent",
		"mcp",
		"codebase-indexing",
		"file-discovery",
		"call-graph",
		"tree-sitter",
		"claude",
		"claude-code",
		"codex",
		"context-recovery",
		"session-history"
	],
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.33.0",
	"files": [
		"dist/src/",
		"dist/web/",
		"README.md",
		"CHANGELOG.md",
		"docs/index.md",
		"docs/getting-started.md",
		"docs/concepts/",
		"docs/guides/",
		"docs/reference/",
		"docs/architecture/",
		"docs/shared/",
		"docs/roadmap.md",
		"docs/assets/demo.gif",
		"LICENSE"
	],
	"bin": {
		"ai-cortex": "dist/src/cli.js"
	},
	"scripts": {
		"prepare": "tsc -p tsconfig.json",
		"build": "tsc -p tsconfig.json && node scripts/build-web.mjs",
		"build:web": "node scripts/build-web.mjs",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json",
		"typecheck:bench": "tsc --noEmit -p benchmarks/tsconfig.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"cortex": "tsx src/cli.ts",
		"release": "bash scripts/release.sh",
		"bench": "tsx benchmarks/runner.ts",
		"bench:perf": "tsx benchmarks/runner.ts --suite perf",
		"bench:quality": "tsx benchmarks/runner.ts --suite quality",
		"bench:update-baseline": "tsx benchmarks/runner.ts --update-baseline",
		"eval": "tsx benchmarks/eval/runner.ts"
	},
	"dependencies": {
		"3d-force-graph": "^1.80.0",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@xenova/transformers": "^2.17.2",
		"better-sqlite3": "^11.10.0",
		"ink": "^7.0.3",
		"ink-spinner": "^5.0.0",
		"js-yaml": "^4.1.1",
		"picomatch": "^4.0.4",
		"react": "^19.2.6",
		"three": "^0.184.0",
		"three-spritetext": "^1.10.0",
		"tree-sitter-c": "^0.23.6",
		"tree-sitter-cpp": "^0.23.4",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-python": "^0.25.0",
		"tree-sitter-typescript": "^0.23.2",
		"web-tree-sitter": "^0.26.8",
		"zod": "^3.0.0"
	},
	"pnpm": {
		"overrides": {
			"protobufjs@<7.5.5": "^7.5.5"
		},
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"sharp",
			"web-tree-sitter",
			"tree-sitter-typescript",
			"tree-sitter-javascript",
			"tree-sitter-python",
			"tree-sitter-c",
			"tree-sitter-cpp"
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^4.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.17",
		"@types/picomatch": "^4.0.3",
		"@types/react": "^19.2.14",
		"@types/three": "^0.184.1",
		"esbuild": "^0.28.0",
		"eslint": "^9.0.0",
		"globals": "^16.0.0",
		"ink-testing-library": "^4.0.0",
		"prettier": "^3.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.0.0",
		"vitest": "^3.2.4"
	},
	"aiCortex": {
		"releaseHeadline": "SQLite structural store + location-aware blast_radius"
	}
}
