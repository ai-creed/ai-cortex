{
	"name": "ai-cortex",
	"version": "0.4.0",
	"description": "Local project rehydration, file discovery, and session-history MCP server for AI agents (Claude Code, Codex)",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ai-creed/ai-cortex.git"
	},
	"homepage": "https://github.com/ai-creed/ai-cortex",
	"keywords": [
		"ai-agent",
		"mcp",
		"codebase-indexing",
		"file-discovery",
		"call-graph",
		"tree-sitter",
		"claude",
		"claude-code",
		"codex",
		"context-recovery",
		"session-history"
	],
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.33.0",
	"files": [
		"dist/src/",
		"README.md",
		"MANUAL.md",
		"LICENSE"
	],
	"bin": {
		"ai-cortex": "dist/src/cli.js"
	},
	"scripts": {
		"prepare": "tsc -p tsconfig.json",
		"build": "tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"typecheck:bench": "tsc --noEmit -p benchmarks/tsconfig.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"cortex": "tsx src/cli.ts",
		"release": "bash scripts/release.sh",
		"bench": "tsx benchmarks/runner.ts",
		"bench:perf": "tsx benchmarks/runner.ts --suite perf",
		"bench:quality": "tsx benchmarks/runner.ts --suite quality",
		"bench:update-baseline": "tsx benchmarks/runner.ts --update-baseline",
		"eval": "tsx benchmarks/eval/runner.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@xenova/transformers": "^2.17.2",
		"better-sqlite3": "^11.10.0",
		"tree-sitter-c": "^0.23.6",
		"tree-sitter-cpp": "^0.23.4",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-python": "^0.25.0",
		"tree-sitter-typescript": "^0.23.2",
		"web-tree-sitter": "^0.26.8",
		"zod": "^3.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"sharp",
			"web-tree-sitter",
			"tree-sitter-typescript",
			"tree-sitter-javascript",
			"tree-sitter-python",
			"tree-sitter-c",
			"tree-sitter-cpp"
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^4.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.15.17",
		"eslint": "^9.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.0.0",
		"vitest": "^3.2.4"
	}
}
