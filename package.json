{
	"name": "ai-cortex",
	"version": "0.1.0-beta.1",
	"type": "module",
	"bin": {
		"ai-cortex": "dist/src/cli.js"
	},
	"scripts": {
		"prepare": "tsc -p tsconfig.json",
		"build": "tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"typecheck:bench": "tsc --noEmit -p benchmarks/tsconfig.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"cortex": "tsx src/cli.ts",
		"release": "bash scripts/release.sh",
		"bench": "tsx benchmarks/runner.ts",
		"bench:perf": "tsx benchmarks/runner.ts --suite perf",
		"bench:quality": "tsx benchmarks/runner.ts --suite quality",
		"bench:update-baseline": "tsx benchmarks/runner.ts --update-baseline"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-typescript": "^0.23.2",
		"web-tree-sitter": "^0.26.8",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^4.0.0",
		"@types/node": "^22.15.17",
		"eslint": "^9.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.0.0",
		"vitest": "^3.2.4"
	}
}
