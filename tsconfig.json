{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true, // web-tree-sitter has incomplete .d.ts declarations
		"noEmit": false,
		"outDir": "dist",
		"rootDir": ".",
		"types": ["node"],
		"jsx": "react",
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "scripts/**/*.ts"],
	"exclude": ["tests/fixtures"]
}
