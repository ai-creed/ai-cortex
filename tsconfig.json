{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true, // web-tree-sitter has incomplete .d.ts declarations
		"noEmit": false,
		"outDir": "dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
